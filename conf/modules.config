// conf/modules.config

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ── TRIMMING ──
    withName: 'FASTP' {
        ext.args = '--detect_adapter_for_pe --trim_poly_g'
        publishDir = [
            path: { "${params.outdir}/fastp/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── QC ──
    withName: 'FASTQC' {
        publishDir = [
            path: { "${params.outdir}/fastqc/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── ASSEMBLY ──
    withName: 'UNICYCLER' {
        ext.args = '--mode bold'
        publishDir = [
            path: { "${params.outdir}/assembly/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── ANNOTATION ──
    withName: 'PROKKA' {
        publishDir = [
            path: { "${params.outdir}/annotation/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'PHAROKKA_PHAROKKA' {
        publishDir = [
            path: { "${params.outdir}/annotation/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── MAPPING TO SELF (assembly) — intermediate, don't publish ──
    withName: '.*PREPARE_ASSEMBLY.*BWA_INDEX' {
        memory = { 4.GB * task.attempt }
        publishDir = [ enabled: false ]
    }
    withName: '.*PREPARE_ASSEMBLY.*BWA_MEM' {
        ext.args = { "-M -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tLB:${meta.id}\\tPL:ILLUMINA'" }
        publishDir = [ enabled: false ]
    }
    withName: '.*PREPARE_ASSEMBLY.*SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/assembly/${meta.id}" },
            mode: 'copy',
            pattern: '*.{bam,bai}',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── MAPPING TO REFERENCES ──
    withName: '.*MAPPING:BWA_INDEX_REF' {
        memory = { 4.GB * task.attempt }
        publishDir = [ enabled: false ]
    }
    withName: '.*MAPPING:BWA_MEM_REF' {
        ext.args = { "-M -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tLB:${meta.id}\\tPL:ILLUMINA'" }
        publishDir = [ enabled: false ]
    }
    withName: '.*MAPPING:PICARD_MARKDUPLICATES' {
        ext.args   = '--ASSUME_SORTED true --VALIDATION_STRINGENCY SILENT --CREATE_INDEX true'
        ext.prefix = { "${meta.id}.dedup" }
        publishDir = [
            path: { "${params.outdir}/mapped/${meta.ref_name}/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── VARIANT CALLING ──
    withName: 'BCFTOOLS_MPILEUP' {
        ext.args  = '-q 0 -Q 0 --max-depth 10000 -a AD,DP'  // mpileup args
        ext.args2 = '-m --ploidy 1 -v'                       // call args
        ext.args3 = ''                                        // view filter (not used here)
        publishDir = [ enabled: false ]
    }
    withName: 'BCFTOOLS_NORM' {
        ext.args   = '-m -both -c w'
        ext.prefix = { "${meta.id}.norm" }
        publishDir = [ enabled: false ]
    }
    withName: '.*CALL_VARIANTS:BCFTOOLS_VIEW' {
        ext.args = "-i 'QUAL>=20 && FMT/DP>=10' --output-type z"
        publishDir = [
            path: { "${params.outdir}/vcf/${meta.ref_name}/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: '.*CALL_VARIANTS:BCFTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/vcf/${meta.ref_name}/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: '.*CALL_VARIANTS:BCFTOOLS_STATS' {
        publishDir = [
            path: { "${params.outdir}/vcf/${meta.ref_name}/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── STATS ──
    withName: 'PICARD_COLLECTWGSMETRICS' {
        ext.args = '--COVERAGE_CAP 100000 --COUNT_UNPAIRED true'
        publishDir = [
            path: { "${params.outdir}/stats/picard/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'PICARD_COLLECTALIGNMENTSUMMARYMETRICS' {
        publishDir = [
            path: { "${params.outdir}/stats/picard/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'SAMTOOLS_STATS' {
        publishDir = [
            path: { "${params.outdir}/stats/samtools/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'SAMTOOLS_FLAGSTAT' {
        publishDir = [
            path: { "${params.outdir}/stats/samtools/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'QUAST' {
        publishDir = [
            path: { "${params.outdir}/quast/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── KRAKEN ──
    withName: 'KRAKEN2_KRAKEN2' {
        ext.args = '--confidence 0.05 --use-names'
        publishDir = [
            path: { "${params.outdir}/kraken2/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'BRACKEN_BRACKEN' {
        ext.args = '-r 50 -l S -t 1'
        publishDir = [
            path: { "${params.outdir}/bracken/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'BRACKEN_COMBINEBRACKENOUTPUTS' {
        publishDir = [
            path: { "${params.outdir}/bracken" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ── CONTIG ABUNDANCE (local) ──
    withName: 'CONTIG_ABUNDANCE' {
        publishDir = [
            path: { "${params.outdir}/stats/contigs/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ── MULTIQC ──
    withName: 'MULTIQC' {
        ext.args = "--title 'ASM-Lite QC'"
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
