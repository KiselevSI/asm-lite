// nextflow.config

params {
    input           = null
    workflow        = 'bacteria'    // 'bacteria' or 'phages'
    outdir          = './results'

    // References for mapping + variant calling
    references      = null          // references.csv: name,fasta

    // Kraken2/Bracken
    kraken2_db      = null

    // Pharokka (phages only)
    pharokka_db     = null

    // MultiQC
    multiqc_config  = "${projectDir}/assets/multiqc_config.yml"

    // Skip steps
    skip_kraken     = false
    skip_variants   = false
    skip_qc         = false
}

// Load base config
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    test {
        params.input      = "${projectDir}/tests/samplesheet.csv"
        params.references = "${projectDir}/tests/references.csv"
        params.outdir     = './results_test'
    }
}

manifest {
    name            = 'asm-lite'
    author          = 'ASM-Lite Team'
    description     = 'Bacterial and phage genome assembly, annotation and variant calling pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '2.0.0'
}
