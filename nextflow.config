// nextflow.config

params {
    input           = null
    outdir          = './results'

    // Annotation: Prokka by default, --pharokka to use Pharokka instead
    pharokka        = false
    pharokka_db     = null

    // Deprecated: reference mapping now reads per-sample FASTA paths from --input: reference
    references      = null

    // Kraken2/Bracken
    kraken2_db      = null

    // MultiQC
    multiqc_config  = "${projectDir}/assets/multiqc_config.yml"

    // Skip steps
    skip_assembly   = false         // skip assembly + annotation + stats
    skip_stats      = false         // skip stats + multiqc
    skip_kraken     = false
    skip_variants   = false
    skip_qc         = false
}

// Load base config
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'
if (!params.skip_assembly) {
    includeConfig 'conf/modules_assembly.config'
}
if (!params.skip_variants) {
    includeConfig 'conf/modules_mapping.config'
}

profiles {
    docker {
        docker.enabled         = true
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    test {
        params.input      = "${projectDir}/tests/samplesheet.csv"
        params.outdir     = './results_test'
        params.skip_kraken = true
    }
}

conda {
    cacheDir = System.getenv('NXF_CONDA_CACHEDIR') ?: "${System.getenv('HOME')}/.nextflow_conda_cache/asm-lite"
}

manifest {
    name            = 'asm-lite'
    author          = 'ASM-Lite Team'
    description     = 'Bacterial and phage genome assembly, annotation and variant calling pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '2.0.0'
}
